@{
    ViewData["Title"] = "QR Code Generator";
}

@{
    var campaigns = ViewBag.Campaigns as List<QRRewardPlatform.Models.Campaign>;
    var generatedBatch = TempData["GeneratedBatch"] as string;
}

<div class="max-w-4xl">
    <!-- Generator Form -->
    <div class="glass-card rounded-2xl border border-gray-100 shadow-sm p-6 mb-8">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Generate QR Codes</h3>
        <form method="post" action="/QRCode/Generate" class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Campaign</label>
                    <select name="campaignId" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                        <option value="">Select campaign...</option>
                        @foreach (var c in campaigns ?? new List<QRRewardPlatform.Models.Campaign>())
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Batch Name (Required)</label>
                    <input type="text" name="batchName" required placeholder="e.g. Diwali Promo 2026" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Quantity</label>
                    <input type="number" name="count" min="1" max="500" value="10" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                </div>
            </div>
            <button type="submit" class="px-6 py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-xl hover:bg-indigo-700 transition flex items-center gap-2">
                <i class="fas fa-qrcode"></i> Generate QR Codes
            </button>
        </form>
    </div>

    @if (!string.IsNullOrEmpty(generatedBatch))
    {
        <!-- Generated Batch -->
        <div class="glass-card rounded-2xl border border-gray-100 shadow-sm p-6">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold text-gray-900">Generated Batch: @generatedBatch</h3>
                <a href="/QRCode/ExportBatch?batchId=@generatedBatch" class="px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-xl hover:bg-green-700 transition flex items-center gap-2">
                    <i class="fas fa-download"></i> Export ZIP
                </a>
            </div>
            <div id="batchCodes" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
                <p class="col-span-full text-gray-500 text-sm">Loading codes...</p>
            </div>
        </div>

        <script>
            fetch('/QRCode/GetBatchCodes?batchId=@generatedBatch')
                .then(r => r.json())
                .then(codes => {
                    const container = document.getElementById('batchCodes');
                    container.innerHTML = codes.map(c => `
                        <div class="bg-gray-50 rounded-xl p-4 text-center">
                            <img src="${c.qrUrl || '/QRCode/DownloadQR?code=' + c.code}" class="w-32 h-32 mx-auto mb-2" alt="QR"/>
                            <p class="text-xs font-mono font-medium text-gray-700">${c.code}</p>
                            <a href="${c.qrUrl || '/QRCode/DownloadQR?code=' + c.code}" target="_blank" class="text-xs text-indigo-600 hover:underline mt-1 inline-block">View QR</a>
                        </div>
                    `).join('');
                });
        </script>
    }
</div>
