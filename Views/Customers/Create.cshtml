@model QRRewardPlatform.Models.Customer
@{
    ViewData["Title"] = "Add Customer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="glass-card rounded-2xl border border-gray-100 shadow-sm p-6 mb-6">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <div>
                <h3 class="text-lg font-semibold text-gray-900">Add New Customer</h3>
                <p class="text-gray-500 text-sm mt-1">Provide the details to register a new user in the system.</p>
            </div>
        </div>
    </div>

    <!-- Form content -->
    <div class="glass-card rounded-2xl border border-gray-100 shadow-sm p-8">
        <form asp-action="Create" method="post" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">Full Name *</label>
                    <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" required />
                </div>
                <div>
                    <label asp-for="MobileNumber" class="block text-sm font-medium text-gray-700 mb-1">Mobile Number *</label>
                    <input asp-for="MobileNumber" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" required pattern="\d{10}" title="10 digit mobile number" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="City" class="block text-sm font-medium text-gray-700 mb-1">City *</label>
                    <input asp-for="City" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" required />
                </div>
                <div>
                    <label asp-for="District" class="block text-sm font-medium text-gray-700 mb-1">District</label>
                    <input asp-for="District" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="Category" class="block text-sm font-medium text-gray-700 mb-1">Category / Role *</label>
                    <select asp-for="Category" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition bg-white" required>
                        <option value="">Select Role...</option>
                        <option value="Contractor">Contractor</option>
                        <option value="Builder">Builder</option>
                        <option value="Supervisor">Supervisor</option>
                        <option value="Painter">Painter</option>
                        <option value="Dealer">Dealer</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

            </div>

            <div class="pt-4 border-t border-gray-100 flex justify-end gap-3">
                <a href="@Url.Action("Index", "Customers")" class="px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-xl hover:bg-gray-50 transition">Cancel</a>
                <button type="submit" class="px-5 py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-xl hover:bg-indigo-700 transition shadow-lg shadow-indigo-200">Save Customer</button>
            </div>
        </form>
    </div>
</div>
