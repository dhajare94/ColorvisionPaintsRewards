@model IEnumerable<QRRewardPlatform.Models.Customer>
@{
    ViewData["Title"] = "Customers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header -->
<div class="glass-card rounded-2xl border border-gray-100 shadow-sm p-6 mb-6">
    <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
            <h3 class="text-lg font-semibold text-gray-900">Customer Management</h3>
            <p class="text-gray-500 text-sm mt-1">Manage users, view engagement metrics, and check ranks.</p>
        </div>
        <a href="@Url.Action("Create", "Customers")" class="px-5 py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-xl hover:bg-indigo-700 transition flex items-center gap-2">
            <i class="fas fa-person-circle-plus"></i> Add New Customer
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="toast mb-4 p-4 bg-green-50 border border-green-200 rounded-xl flex items-center gap-3">
        <i class="fas fa-check-circle text-green-600"></i>
        <span class="text-green-800 text-sm font-medium">@TempData["SuccessMessage"]</span>
    </div>
}

<div class="glass-card rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-100">
        <h3 class="font-semibold text-gray-900">All Customers</h3>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-gray-50">
                <tr>

                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Contact</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Location</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role / Rank</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Activity</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center text-gray-400">No customers found.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50">

                            <td class="px-6 py-3 font-medium text-gray-900">@item.Name</td>
                            <td class="px-6 py-3 text-gray-700">@item.MobileNumber</td>
                            <td class="px-6 py-3">
                                <span class="text-gray-900">@item.City</span><br />
                                <span class="text-gray-500 text-xs">@item.District</span>
                            </td>
                            <td class="px-6 py-3">
                                <span class="px-2 py-1 text-xs font-medium rounded-full badge-unused mb-1 inline-block">@item.Category</span><br />
                                <span class="text-indigo-600 text-xs font-semibold">@item.Rank</span>
                            </td>
                            <td class="px-6 py-3 text-right">
                                <div class="text-gray-900">Bags: <span class="font-semibold">@item.TotalBagsRedeemed</span></div>
                                <div class="text-green-600 text-xs font-medium mt-1">₹@item.TotalRewards.ToString("N0")</div>
                            </td>
                            <td class="px-6 py-3 text-right">
                                <a href="/Customers/Profile/@item.Id" class="text-sm text-indigo-600 hover:text-indigo-800 font-medium transition flex items-center justify-end gap-1">
                                    View Profile <i class="fas fa-arrow-right"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
