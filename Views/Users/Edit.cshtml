@model QRRewardPlatform.Models.AdminUser
@{
    ViewData["Title"] = "Edit User";
}

<div class="max-w-3xl mx-auto">
    <div class="mb-6 flex items-center gap-4">
        <a href="/Users" class="w-10 h-10 rounded-full bg-white border border-gray-200 flex items-center justify-center text-gray-600 hover:bg-gray-50 transition">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Edit User</h1>
            <p class="text-sm text-gray-500">Update admin or staff information</p>
        </div>
    </div>

    <form action="/Users/Edit/@Model.Id" method="post" enctype="multipart/form-data" class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="p-6 lg:p-8 space-y-6">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Username (Read Only) -->
                <div class="col-span-1 md:col-span-2">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Username (Read Only)</label>
                    <input type="text" value="@Model.Username" readonly class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-gray-100 text-gray-500 focus:outline-none" />
                </div>

                <!-- Display Name -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
                    <input type="text" name="displayName" value="@Model.DisplayName" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" />
                </div>

                <!-- Role -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Role</label>
                    <select name="role" id="roleSelect" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition">
                        @if (User.IsInRole("Admin"))
                        {
                            @if (Model.Role == "Admin")
                            {
                                <option value="Staff">Staff</option>
                                <option value="Admin" selected>Admin</option>
                            }
                            else
                            {
                                <option value="Staff" selected>Staff</option>
                                <option value="Admin">Admin</option>
                            }
                        }
                        else
                        {
                            <option value="Staff" selected>Staff</option>
                        }
                    </select>
                </div>

                <!-- Phone Number -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
                    <input type="tel" name="phoneNumber" value="@Model.PhoneNumber" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" />
                </div>

                <!-- Email -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input type="email" name="email" value="@Model.Email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" />
                </div>

                <!-- Profile Image -->
                <div class="col-span-1 md:col-span-2">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Update Profile Image</label>
                    @if (!string.IsNullOrEmpty(Model.ProfileImage))
                    {
                        <div class="mb-3">
                            <span class="text-xs text-gray-500 block mb-2">Current Image:</span>
                            <img src="@Model.ProfileImage" alt="Profile" class="w-16 h-16 rounded-lg object-cover border border-gray-200" />
                        </div>
                    }
                    <input type="file" name="profileImage" accept="image/*" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" />
                    <p class="text-xs text-gray-500 mt-1">Leave empty to keep current image.</p>
                </div>
            </div>

            <hr class="border-gray-100" />

            <!-- Permissions -->
            <div id="permissionsSection" style="@(Model.Role == "Admin" ? "opacity: 0.5;" : "opacity: 1;")">
                <h3 class="text-lg font-medium text-gray-900 mb-4">Module Permissions</h3>
                <p class="text-sm text-gray-500 mb-4">Select the modules this user is allowed to access.</p>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
                    @{
                        var modules = new[] { "Dashboard", "Campaigns", "Reward Slabs", "QR Generator", "Codes Manager", "Redemptions", "Payouts", "Users", "Customers" };
                        var currentPerms = Model.Permissions ?? new List<string>();
                        
                        foreach (var mod in modules)
                        {
                            var isChecked = currentPerms.Contains(mod) || Model.Role == "Admin" ? "checked" : "";
                            var isDisabled = Model.Role == "Admin" ? "disabled" : "";
                            
                            <label class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:bg-gray-50 cursor-pointer transition">
                                <input type="checkbox" name="permissions[]" value="@mod" @isChecked @isDisabled class="w-4 h-4 text-indigo-600 rounded border-gray-300 focus:ring-indigo-500" />
                                <span class="text-sm font-medium text-gray-700">@mod</span>
                            </label>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end gap-3">
            <a href="/Users" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition">Cancel</a>
            <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition">Save Changes</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById('roleSelect').addEventListener('change', function(e) {
            const permissionsSection = document.getElementById('permissionsSection');
            const checkboxes = permissionsSection.querySelectorAll('input[type="checkbox"]');
            
            if (e.target.value === 'Admin') {
                checkboxes.forEach(cb => {
                    cb.checked = true;
                    cb.disabled = true;
                });
                permissionsSection.style.opacity = '0.5';
            } else {
                checkboxes.forEach(cb => {
                    cb.checked = false;
                    cb.disabled = false;
                });
                permissionsSection.style.opacity = '1';
            }
        });
    </script>
}
