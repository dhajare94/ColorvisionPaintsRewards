@model IEnumerable<QRRewardPlatform.Models.AdminUser>
@{
    ViewData["Title"] = "Users Management";
}

<div class="mb-6 flex justify-between items-center">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Users</h1>
        <p class="text-sm text-gray-500">Manage admin portal users and their access</p>
    </div>
    <a href="/Users/Create" class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition flex items-center gap-2">
        <i class="fas fa-plus"></i> Create User
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-gray-600">
            <thead class="bg-gray-50 text-gray-700">
                <tr>
                    <th class="px-6 py-4 font-semibold">User</th>
                    <th class="px-6 py-4 font-semibold">Username</th>
                    <th class="px-6 py-4 font-semibold">Role</th>
                    <th class="px-6 py-4 font-semibold">Contact</th>
                    <th class="px-6 py-4 font-semibold">Last Login</th>
                    <th class="px-6 py-4 text-right font-semibold">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var user in Model)
                {
                    <tr class="hover:bg-gray-50 transition">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                @if (!string.IsNullOrEmpty(user.ProfileImage))
                                {
                                    <img src="@user.ProfileImage" class="w-10 h-10 rounded-full object-cover border border-gray-200" alt="Profile" />
                                }
                                else
                                {
                                    <div class="w-10 h-10 rounded-full gradient-bg flex items-center justify-center text-white font-bold text-sm">
                                        @(user.DisplayName?.FirstOrDefault() ?? 'U')
                                    </div>
                                }
                                <div>
                                    <div class="font-medium text-gray-900">@user.DisplayName</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                @user.Username
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            @if (user.Role == "Admin")
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                                    Admin
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                    @user.Role
                                </span>
                            }
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex flex-col text-xs space-y-1">
                                @if (!string.IsNullOrEmpty(user.Email))
                                {
                                    <span class="flex items-center gap-1"><i class="fas fa-envelope text-gray-400"></i> @user.Email</span>
                                }
                                @if (!string.IsNullOrEmpty(user.PhoneNumber))
                                {
                                    <span class="flex items-center gap-1"><i class="fas fa-phone text-gray-400"></i> @user.PhoneNumber</span>
                                }
                            </div>
                        </td>
                        <td class="px-6 py-4 text-xs text-gray-500">
                            @(string.IsNullOrEmpty(user.LastLogin) ? "Never" : DateTime.Parse(user.LastLogin).ToString("MMM dd, yyyy HH:mm"))
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                @if (user.Role != "Admin" || User.IsInRole("Admin"))
                                {
                                    <a href="/Users/Edit/@user.Id" class="text-indigo-600 hover:text-indigo-900 bg-indigo-50 hover:bg-indigo-100 p-2 rounded-lg transition" title="Edit User">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                }
                                @if (User.IsInRole("Admin"))
                                {
                                    <form action="/Users/Delete/@user.Id" method="post" onsubmit="return confirm('Are you sure you want to delete @user.DisplayName?');" class="inline-block">
                                        <button type="submit" class="text-red-600 hover:text-red-900 bg-red-50 hover:bg-red-100 p-2 rounded-lg transition" title="Delete User">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
