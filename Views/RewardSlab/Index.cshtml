@{
    ViewData["Title"] = "Reward Budgets";
}
@model List<QRRewardPlatform.Models.RewardSlab>

<div class="flex items-center justify-between mb-6">
    <p class="text-gray-500">Manage reward budgets for QR code generation</p>
    <button onclick="openCreateSlab()" class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-xl hover:bg-indigo-700 transition flex items-center gap-2">
        <i class="fas fa-plus"></i> New Budget
    </button>
</div>

<!-- Slabs Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    @foreach (var slab in Model)
    {
        <div class="glass-card rounded-2xl border border-gray-100 shadow-sm p-6 flex flex-col">
            <div class="flex items-center justify-between mb-2">
                <h3 class="text-lg font-semibold text-gray-900 truncate" title="@slab.Name">@slab.Name</h3>
                @if (slab.ZeroRewardAllowed)
                {
                    <span class="px-2 py-1 text-[10px] font-medium rounded-full bg-blue-100 text-blue-700">₹0 Allowed</span>
                }
            </div>
            @if (!string.IsNullOrEmpty(slab.Date))
            {
                <p class="text-xs text-gray-400 mb-4"><i class="far fa-calendar-alt mr-1"></i> @slab.Date</p>
            }

            <div class="bg-gray-50 rounded-xl p-4 mb-4 grid grid-cols-2 gap-4">
                <div>
                    <p class="text-xs text-gray-500 mb-1">Budget</p>
                    <p class="font-semibold text-gray-900">₹@slab.TotalBudget.ToString("N0")</p>
                </div>
                <div>
                    <p class="text-xs text-gray-500 mb-1">Coupons Generated</p>
                    <p class="font-semibold text-gray-900">@slab.GeneratedCoupons</p>
                </div>
                <div>
                    <p class="text-xs text-indigo-500 mb-1">Allocated (Lifetime)</p>
                    <p class="font-semibold text-indigo-700">₹@slab.AllocatedAmount.ToString("N0")</p>
                </div>
                <div>
                    <p class="text-xs text-green-500 mb-1">Redeemed</p>
                    <p class="font-semibold text-green-700">₹@slab.RedeemedAmount.ToString("N0")</p>
                </div>
            </div>

            <div class="flex gap-2 mt-auto">
                <button onclick="editSlab('@slab.Id')" class="flex-1 px-3 py-2 text-sm text-indigo-600 bg-indigo-50 rounded-xl hover:bg-indigo-100 transition">
                    <i class="fas fa-edit mr-1"></i> Edit
                </button>
                <form method="post" action="/RewardSlab/Delete" class="flex-1" onsubmit="return confirm('Delete this budget?')">
                    <input type="hidden" name="id" value="@slab.Id" />
                    <button type="submit" class="w-full px-3 py-2 text-sm text-red-600 bg-red-50 rounded-xl hover:bg-red-100 transition">
                        <i class="fas fa-trash mr-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-span-full text-center py-12 text-gray-400">
            <i class="fas fa-wallet text-4xl mb-3"></i>
            <p>No budgets created yet. Create your first!</p>
        </div>
    }
</div>

<!-- Create/Edit Modal -->
<div id="slabModal" class="fixed inset-0 z-50 hidden modal-overlay flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm transform transition-all">
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 bg-gray-50 rounded-t-2xl">
            <h3 class="text-lg font-bold text-gray-900" id="slabModalTitle"><i class="fas fa-wallet text-indigo-600 mr-2"></i>Create Budget</h3>
            <button type="button" onclick="closeModal('slabModal')" class="p-1 hover:bg-gray-200 rounded-lg transition"><i class="fas fa-times text-gray-400 hover:text-gray-600"></i></button>
        </div>
        <form id="slabForm" method="post" class="p-6 space-y-4">
            <input type="hidden" name="id" id="slabId" />

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Budget Name</label>
                <input type="text" name="name" id="slabName" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" placeholder="e.g. Diwali Promo" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Budget Amount (₹)</label>
                <input type="number" step="1" min="1" name="totalBudget" id="totalBudget" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" placeholder="e.g. 1500" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Date</label>
                <input type="text" name="date" id="slabDate" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" placeholder="e.g. March 2026" />
            </div>

            <div class="flex items-center gap-2 py-2">
                <input type="checkbox" name="zeroRewardAllowed" id="zeroRewardAllowed" value="true" checked class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
                <label for="zeroRewardAllowed" class="text-sm text-gray-700 cursor-pointer">Allow ₹0 Reward</label>
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
                <button type="button" onclick="closeModal('slabModal')" class="px-5 py-2.5 text-gray-700 bg-gray-100 rounded-xl hover:bg-gray-200 transition text-sm font-medium">Cancel</button>
                <button type="submit" class="px-5 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition text-sm font-medium shadow-sm flex items-center gap-2">
                    <i class="fas fa-save"></i> Save Budget
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function openCreateSlab() {
        document.getElementById('slabModalTitle').innerHTML = '<i class="fas fa-wallet text-indigo-600 mr-2"></i>Create Budget';
        document.getElementById('slabForm').action = '/RewardSlab/Create';
        document.getElementById('slabId').value = '';
        document.getElementById('slabName').value = '';
        document.getElementById('totalBudget').value = '';
        document.getElementById('slabDate').value = '';
        document.getElementById('zeroRewardAllowed').checked = true;
        openModal('slabModal');
    }

    async function editSlab(id) {
        const res = await fetch(`/RewardSlab/GetSlab?id=${id}`);
        const slab = await res.json();
        document.getElementById('slabModalTitle').innerHTML = '<i class="fas fa-wallet text-indigo-600 mr-2"></i>Edit Budget';
        document.getElementById('slabForm').action = `/RewardSlab/Edit?id=${id}`;
        document.getElementById('slabId').value = id;
        document.getElementById('slabName').value = slab.name;
        document.getElementById('totalBudget').value = slab.totalBudget;
        document.getElementById('slabDate').value = slab.date || '';
        document.getElementById('zeroRewardAllowed').checked = slab.zeroRewardAllowed;
        openModal('slabModal');
    }
</script>
}
