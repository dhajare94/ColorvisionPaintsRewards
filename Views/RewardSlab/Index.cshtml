@{
    ViewData["Title"] = "Reward Slabs";
}
@model List<QRRewardPlatform.Models.RewardSlab>

<div class="flex items-center justify-between mb-6">
    <p class="text-gray-500">Manage reward structures</p>
    <button onclick="openCreateSlab()" class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-xl hover:bg-indigo-700 transition flex items-center gap-2">
        <i class="fas fa-plus"></i> New Reward Slab
    </button>
</div>

<!-- Slabs Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    @foreach (var slab in Model)
    {
        <div class="glass-card rounded-2xl border border-gray-100 shadow-sm p-6">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-semibold text-gray-900">@slab.Name</h3>
                <span class="px-2 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-700">
                    Random Range
                </span>
            </div>
            
            <div class="bg-gray-50 rounded-xl p-4 mb-4 flex items-center justify-between">
                <div>
                    <p class="text-xs text-gray-500 mb-1">Min Reward</p>
                    <p class="font-semibold text-gray-900">₹@slab.MinAmount.ToString("N2")</p>
                </div>
                <div class="text-gray-400">
                    <i class="fas fa-arrow-right"></i>
                </div>
                <div class="text-right">
                    <p class="text-xs text-gray-500 mb-1">Max Reward</p>
                    <p class="font-semibold text-gray-900">₹@slab.MaxAmount.ToString("N2")</p>
                </div>
            </div>
            
            <p class="text-xs text-gray-500 text-center mb-4">Users will receive a random <br/>amount between min and max.</p>

            <div class="flex gap-2">
                <button onclick="editSlab('@slab.Id')" class="flex-1 px-3 py-2 text-sm text-indigo-600 bg-indigo-50 rounded-xl hover:bg-indigo-100 transition">
                    <i class="fas fa-edit mr-1"></i> Edit
                </button>
                <form method="post" action="/RewardSlab/Delete" class="flex-1" onsubmit="return confirm('Delete this slab?')">
                    <input type="hidden" name="id" value="@slab.Id" />
                    <button type="submit" class="w-full px-3 py-2 text-sm text-red-600 bg-red-50 rounded-xl hover:bg-red-100 transition">
                        <i class="fas fa-trash mr-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-span-full text-center py-12 text-gray-400">
            <i class="fas fa-layer-group text-4xl mb-3"></i>
            <p>No reward slabs yet. Create your first!</p>
        </div>
    }
</div>

<!-- Create/Edit Modal -->
<div id="slabModal" class="fixed inset-0 z-50 hidden modal-overlay flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
            <h3 class="text-lg font-semibold text-gray-900" id="slabModalTitle">Create Reward Slab</h3>
            <button onclick="closeModal('slabModal')" class="p-1 hover:bg-gray-100 rounded-lg"><i class="fas fa-times text-gray-400"></i></button>
        </div>
        <form id="slabForm" method="post" class="p-6 space-y-4">
            <input type="hidden" name="id" id="slabId" />
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Slab Name</label>
                <input type="text" name="name" id="slabName" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Min Amount (₹)</label>
                    <input type="number" step="0.01" min="0" name="minAmount" id="minAmount" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Max Amount (₹)</label>
                    <input type="number" step="0.01" min="0" name="maxAmount" id="maxAmount" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                </div>
            </div>
            <div class="flex justify-end gap-3 pt-4">
                <button type="button" onclick="closeModal('slabModal')" class="px-4 py-2 text-gray-700 bg-gray-100 rounded-xl hover:bg-gray-200 transition">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition">Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function openCreateSlab() {
        document.getElementById('slabModalTitle').textContent = 'Create Reward Slab';
        document.getElementById('slabForm').action = '/RewardSlab/Create';
        document.getElementById('slabId').value = '';
        document.getElementById('slabName').value = '';
        document.getElementById('minAmount').value = '';
        document.getElementById('maxAmount').value = '';
        openModal('slabModal');
    }

    async function editSlab(id) {
        const res = await fetch(`/RewardSlab/GetSlab?id=${id}`);
        const slab = await res.json();
        document.getElementById('slabModalTitle').textContent = 'Edit Reward Slab';
        document.getElementById('slabForm').action = `/RewardSlab/Edit?id=${id}`;
        document.getElementById('slabId').value = id;
        document.getElementById('slabName').value = slab.name;
        document.getElementById('minAmount').value = slab.minAmount;
        document.getElementById('maxAmount').value = slab.maxAmount;
        openModal('slabModal');
    }
</script>
}
