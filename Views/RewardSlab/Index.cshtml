@{
    ViewData["Title"] = "Reward Slabs & Budgets";
}
@model List<QRRewardPlatform.Models.RewardSlab>

<div class="flex items-center justify-between mb-6">
    <p class="text-gray-500">Manage reward structures and budgets</p>
    <button onclick="openCreateSlab()" class="px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-xl hover:bg-indigo-700 transition flex items-center gap-2">
        <i class="fas fa-plus"></i> New Budget
    </button>
</div>

<!-- Slabs Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    @foreach (var slab in Model)
    {
        decimal remainingBudget = slab.TotalBudget - slab.AllocatedAmount;
        decimal utilizationPct = slab.TotalBudget > 0 ? (slab.AllocatedAmount / slab.TotalBudget) * 100 : 0;
        decimal redemptionPct = slab.TotalBudget > 0 ? (slab.RedeemedAmount / slab.TotalBudget) * 100 : 0;
        
        string statusTag = "Active";
        string statusColor = "bg-green-100 text-green-700";
        if (remainingBudget <= 0) {
            statusTag = "Exhausted";
            statusColor = "bg-red-100 text-red-700";
        } else if (remainingBudget < (slab.TotalBudget * 0.2m)) {
            statusTag = "Low Balance";
            statusColor = "bg-yellow-100 text-yellow-700";
        }

        <div class="glass-card rounded-2xl border border-gray-100 shadow-sm p-6 flex flex-col">
            <div class="flex items-center justify-between mb-2">
                <h3 class="text-lg font-semibold text-gray-900 truncate" title="@slab.Name">@slab.Name</h3>
                <span class="px-2 py-1 text-xs font-medium rounded-full @statusColor">
                    @statusTag
                </span>
            </div>
            @if (!string.IsNullOrEmpty(slab.Validity)) {
                <p class="text-xs text-gray-400 mb-4"><i class="far fa-calendar-alt mr-1"></i> Valid till: @slab.Validity</p>
            } else {
                <p class="text-xs text-gray-400 mb-4"><i class="far fa-calendar-alt mr-1"></i> No expiry</p>
            }

            <div class="bg-gray-50 rounded-xl p-4 mb-4 grid grid-cols-2 gap-4">
                <div>
                    <p class="text-xs text-gray-500 mb-1">Total Budget</p>
                    <p class="font-semibold text-gray-900">₹@slab.TotalBudget.ToString("N2")</p>
                </div>
                <div>
                    <p class="text-xs text-gray-500 mb-1">Coupons</p>
                    <p class="font-semibold text-gray-900">@slab.GeneratedCoupons</p>
                </div>
                <div>
                    <p class="text-xs text-indigo-500 mb-1">Allocated</p>
                    <p class="font-semibold text-indigo-700">₹@slab.AllocatedAmount.ToString("N2")</p>
                </div>
                <div>
                    <p class="text-xs text-green-500 mb-1">Redeemed</p>
                    <p class="font-semibold text-green-700">₹@slab.RedeemedAmount.ToString("N2")</p>
                </div>
            </div>
            
            <div class="mb-4 mt-auto">
                <div class="flex justify-between text-xs mb-1">
                    <span class="text-gray-500 font-medium">Lifetime Utilization</span>
                    <span class="text-gray-900">₹@slab.AllocatedAmount.ToString("N2")</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-1.5 flex overflow-hidden">
                    <div class="bg-indigo-600 h-1.5 transition-all duration-500" style="width: @Math.Min(100, utilizationPct).ToString("F0")%"></div>
                </div>
                <div class="mt-3 space-y-1">
                    <p class="text-[10px] text-gray-400 capitalize"><i class="fas fa-cog mr-1"></i> Mode: @slab.RandomMode</p>
                    <p class="text-[10px] text-gray-400"><i class="fas fa-coins mr-1"></i> Values: <span class="text-gray-500">@slab.AllowedRewardValues</span></p>
                </div>
            </div>

            <div class="flex gap-2">
                <button onclick="editSlab('@slab.Id')" class="flex-1 px-3 py-2 text-sm text-indigo-600 bg-indigo-50 rounded-xl hover:bg-indigo-100 transition">
                    <i class="fas fa-edit mr-1"></i> Edit
                </button>
                <form method="post" action="/RewardSlab/Delete" class="flex-1" onsubmit="return confirm('Delete this budget? Generated codes will lose their mapping.')">
                    <input type="hidden" name="id" value="@slab.Id" />
                    <button type="submit" class="w-full px-3 py-2 text-sm text-red-600 bg-red-50 rounded-xl hover:bg-red-100 transition">
                        <i class="fas fa-trash mr-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-span-full text-center py-12 text-gray-400">
            <i class="fas fa-wallet text-4xl mb-3"></i>
            <p>No budgets created yet. Create your first!</p>
        </div>
    }
</div>

<!-- Create/Edit Modal -->
<div id="slabModal" class="fixed inset-0 z-50 hidden modal-overlay flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm max-h-[90vh] overflow-y-auto transform transition-all">
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 bg-gray-50">
            <h3 class="text-lg font-bold text-gray-900" id="slabModalTitle"><i class="fas fa-wallet text-indigo-600 mr-2"></i>Create Budget</h3>
            <button type="button" onclick="closeModal('slabModal')" class="p-1 hover:bg-gray-200 rounded-lg transition"><i class="fas fa-times text-gray-400 hover:text-gray-600"></i></button>
        </div>
        <form id="slabForm" method="post" class="p-6 space-y-4">
            <input type="hidden" name="id" id="slabId" />
            
            <div id="slabError" class="hidden bg-red-50 border border-red-200 text-red-600 text-xs p-2 rounded-lg mb-4"></div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Budget Name</label>
                <input type="text" name="name" id="slabName" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" placeholder="e.g. Diwali Promo" />
            </div>
            
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Total Budget (₹)</label>
                    <input type="number" step="0.01" min="0" name="totalBudget" id="totalBudget" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" placeholder="e.g. 1500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Validity</label>
                    <input type="text" name="validity" id="validity" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" placeholder="e.g. Dec 2026" />
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Allowed Rewards (₹)</label>
                <input type="text" name="allowedRewardValues" id="allowedRewardValues" required class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" placeholder="e.g. 0,2,5,10,20,50" />
                <p class="text-[10px] text-gray-400 mt-1">Comma separated values that can be assigned.</p>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Relative Weights</label>
                <input type="text" name="rewardWeights" id="rewardWeights" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" placeholder="e.g. 10,50,20,10,7,3" />
                <p class="text-[10px] text-gray-400 mt-1">Order must match allowed rewards. Higher = more frequent.</p>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Distribution</label>
                    <select name="randomMode" id="randomMode" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm">
                        <option value="Curiosity">Curiosity-Driven</option>
                        <option value="Equal">Equal (approx)</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Max Surprises</label>
                    <input type="number" name="maxHighRewardCount" id="maxHighRewardCount" min="0" value="0" class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent" />
                </div>
            </div>

            <div class="flex items-center gap-6 py-2">
                <label class="flex items-center gap-2 cursor-pointer">
                    <input type="checkbox" name="zeroRewardAllowed" id="zeroRewardAllowed" value="true" checked class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
                    <span class="text-sm text-gray-700">Allow ₹0 Reward</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                    <input type="checkbox" name="isReusable" id="isReusable" value="true" checked class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
                    <span class="text-sm text-gray-700">Reusable Template</span>
                </label>
            </div>

            <div class="flex justify-end gap-3 pt-4 border-t border-gray-100 mt-6">
                <button type="button" onclick="closeModal('slabModal')" class="px-5 py-2.5 text-gray-700 bg-gray-100 rounded-xl hover:bg-gray-200 transition text-sm font-medium">Cancel</button>
                <button type="submit" class="px-5 py-2.5 bg-indigo-600 text-white rounded-xl hover:bg-indigo-700 transition text-sm font-medium shadow-sm flex items-center gap-2">
                    <i class="fas fa-save"></i> Save Budget
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function openCreateSlab() {
        document.getElementById('slabModalTitle').innerHTML = '<i class="fas fa-wallet text-indigo-600 mr-2"></i>Create Reward Template';
        document.getElementById('slabForm').action = '/RewardSlab/Create';
        document.getElementById('slabId').value = '';
        document.getElementById('slabName').value = '';
        document.getElementById('totalBudget').value = '1500';
        document.getElementById('validity').value = '';
        document.getElementById('allowedRewardValues').value = '0,2,5,10,20,50';
        document.getElementById('rewardWeights').value = '10,50,20,10,7,3';
        document.getElementById('randomMode').value = 'Curiosity';
        document.getElementById('maxHighRewardCount').value = '0';
        document.getElementById('zeroRewardAllowed').checked = true;
        document.getElementById('isReusable').checked = true;
        document.getElementById('slabError').classList.add('hidden');
        openModal('slabModal');
    }

    async function editSlab(id) {
        const res = await fetch(`/RewardSlab/GetSlab?id=${id}`);
        const slab = await res.json();
        document.getElementById('slabModalTitle').innerHTML = '<i class="fas fa-wallet text-indigo-600 mr-2"></i>Edit Reward Template';
        document.getElementById('slabForm').action = `/RewardSlab/Edit?id=${id}`;
        document.getElementById('slabId').value = id;
        document.getElementById('slabName').value = slab.name;
        document.getElementById('totalBudget').value = slab.totalBudget;
        document.getElementById('validity').value = slab.validity || '';
        document.getElementById('allowedRewardValues').value = slab.allowedRewardValues || '0,2,5,10,20,50';
        document.getElementById('rewardWeights').value = slab.rewardWeights || '';
        document.getElementById('randomMode').value = slab.randomMode || 'Curiosity';
        document.getElementById('maxHighRewardCount').value = slab.maxHighRewardCount || 0;
        document.getElementById('zeroRewardAllowed').checked = slab.zeroRewardAllowed;
        document.getElementById('isReusable').checked = slab.isReusable;
        document.getElementById('slabError').classList.add('hidden');
        openModal('slabModal');
    }
</script>
}
