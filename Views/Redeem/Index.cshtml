@{
    Layout = "_RedeemLayout";
    ViewData["Title"] = "Claim Reward - Colorvision Paints";
    var isFollowed = ViewBag.InstagramFollowed ?? false;
    var sessionName = ViewBag.SessionName;
    var sessionMobile = ViewBag.SessionMobile;
    var sessionCity = ViewBag.SessionCity;
    var sessionDistrict = ViewBag.SessionDistrict;
}

<style>
    :root {
        --primary: #3b82f6;
        --primary-dark: #2563eb;
        --secondary: #6366f1;
        --bg-color: #f8fafc;
        --card-bg: #ffffff;
        --text-main: #1e293b;
        --text-muted: #64748b;
    }

    body {
        background-color: var(--bg-color);
        color: var(--text-main);
        overflow-x: hidden;
    }

    .glass-card {
        background: var(--card-bg);
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
    }

    .step-content {
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .fade-out {
        opacity: 0;
        transform: translateX(-20px);
        pointer-events: none;
        position: absolute;
    }

    .fade-in {
        opacity: 1;
        transform: translateX(0);
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
        box-shadow: 0 4px 14px 0 rgba(59, 130, 246, 0.39);
        transition: all 0.3s ease;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(59, 130, 246, 0.23);
    }

    .input-field {
        border-bottom: 2px solid #e2e8f0;
        transition: border-color 0.3s ease;
    }

    .input-field:focus {
        border-color: var(--primary);
    }

    .nav-dot.active {
        background-color: var(--primary);
        width: 1.5rem;
    }

    .insta-button {
        background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fdf497 5%, #fd5949 45%, #d6249f 60%, #285AEB 90%);
    }
</style>

<main class="min-h-screen flex flex-col items-center justify-center p-6 sm:p-12 relative overflow-hidden">
    <!-- Background Decor -->
    <div class="absolute -top-24 -left-24 w-96 h-96 bg-primary/5 rounded-full blur-[100px]"></div>
    <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-secondary/5 rounded-full blur-[100px]"></div>

    <!-- Center Content -->
    <div class="w-full max-w-md z-10">
        <!-- Logo -->
        <div class="text-center mb-10">
            <img src="/images/logo.png" alt="Colorvision Paints" class="h-16 mx-auto mb-2 drop-shadow-sm" />
            <div class="h-1 w-12 bg-primary mx-auto rounded-full mt-4"></div>
        </div>

        @if (ViewBag.Status == "success")
        {
            <div class="text-center space-y-8 animate-fadeIn">
                <div class="relative w-32 h-32 mx-auto">
                    <div class="absolute inset-0 bg-green-500/20 rounded-full animate-ping"></div>
                    <div class="relative bg-white rounded-full shadow-2xl p-6 border-4 border-green-500">
                        <span class="material-symbols-outlined text-green-500 text-6xl">check_circle</span>
                    </div>
                </div>
                
                <div class="space-y-2">
                    <h2 class="text-3xl font-black text-slate-900">Success! 🎉</h2>
                    <p class="text-slate-500 font-medium">Your reward has been claimed.</p>
                </div>

                <div class="glass-card rounded-3xl p-8 border border-slate-100 shadow-xl relative group">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Reward Value</p>
                    <p class="text-6xl font-black text-slate-800">₹@ViewBag.Reward.ToString("N0")</p>
                </div>

                <div class="grid grid-cols-1 gap-4">
                    <a href="/Redeem?autoScan=true" class="btn-primary w-full py-5 rounded-2xl text-white font-bold text-lg uppercase tracking-widest flex items-center justify-center gap-3">
                        <span class="material-symbols-outlined">qr_code_scanner</span>
                        Scan Another QR
                    </a>
                    <a href="/CustomerDashboard" class="text-primary font-bold text-sm tracking-wide uppercase hover:opacity-80 transition-opacity">
                        View Dashboard
                    </a>
                </div>
            </div>
        }
        else if (ViewBag.Status == "invalid" || ViewBag.Status == "redeemed" || ViewBag.Status == "error")
        {
             <div class="text-center space-y-8 animate-fadeIn">
                <div class="w-24 h-24 bg-red-50 text-red-500 rounded-3xl flex items-center justify-center mx-auto shadow-inner border border-red-100">
                    <span class="material-symbols-outlined text-5xl">@(ViewBag.Status == "redeemed" ? "warning" : "error")</span>
                </div>
                
                <div class="space-y-4">
                    <h2 class="text-3xl font-black text-slate-900">@(ViewBag.Status == "invalid" ? "Invalid Code" : (ViewBag.Status == "redeemed" ? "Used Code" : "Notice"))</h2>
                    <p class="text-slate-500 leading-relaxed max-w-sm mx-auto">@ViewBag.Message</p>
                </div>

                <a href="/Redeem" class="inline-flex items-center gap-2 text-primary font-bold text-sm uppercase tracking-widest group">
                    <span class="material-symbols-outlined transition-transform group-hover:-translate-x-1">arrow_back</span>
                    Try with another code
                </a>
            </div>
        }
        else if (ViewBag.Status == "registered")
        {
             <div class="text-center space-y-8 animate-fadeIn">
                <div class="w-24 h-24 bg-blue-50 text-primary rounded-3xl flex items-center justify-center mx-auto shadow-inner border border-blue-100">
                    <span class="material-symbols-outlined text-5xl">person_check</span>
                </div>
                
                <div class="space-y-4">
                    <h2 class="text-3xl font-black text-slate-900">Registered!</h2>
                    <p class="text-slate-500 leading-relaxed max-w-sm mx-auto">@ViewBag.Message</p>
                </div>

                <a href="/Redeem?autoScan=true" class="btn-primary w-full py-5 rounded-2xl text-white font-bold text-lg uppercase tracking-widest flex items-center justify-center gap-3">
                    <span class="material-symbols-outlined">qr_code_scanner</span>
                    Start Scanning QR
                </a>
            </div>
        }
        else
        {
            <div class="relative min-h-[500px]">
                
                @if (!isFollowed && ViewBag.InstagramUrl != null)
                {
                    <div id="instaStep" class="step-content text-center space-y-8 absolute inset-0 py-10">
                        <div class="w-20 h-20 insta-button text-white rounded-3xl flex items-center justify-center mx-auto shadow-lg hover:scale-105 transition-transform">
                            <i class="fab fa-instagram text-4xl"></i>
                        </div>
                        <div class="space-y-3">
                            <h2 class="text-2xl font-black text-slate-800">Follow to Unlock</h2>
                            <p class="text-slate-500 font-medium">Follow our Instagram page to claim your paint rewards.</p>
                        </div>
                        <a href="@ViewBag.InstagramUrl" target="_blank" onclick="markFollowed()" class="insta-button block py-5 px-8 rounded-full text-white font-bold shadow-xl hover:opacity-95 transition-opacity">
                            FOLLOW @@ColorvisionPaints
                        </a>
                        <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest cursor-pointer hover:text-slate-600" onclick="showFirstStep()">Skip (For Testing)</p>
                    </div>
                }

                <!-- Step 1: Mobile Number -->
                <div id="step1" class="step-content absolute inset-0 @(!isFollowed ? "opacity-0 pointer-events-none translate-x-20" : "")">
                    <div class="space-y-2 mb-10 text-center">
                        <span class="text-xs font-black text-primary uppercase tracking-[0.2em] mb-2 block">Step 01</span>
                        <h1 class="text-3xl font-black text-slate-800">Enter Number</h1>
                        <p class="text-slate-500 font-medium">Let's check your rewards eligibility.</p>
                    </div>

                    <div class="space-y-8">
                        <div class="relative">
                            <label class="absolute -top-3 left-4 bg-white px-2 text-[10px] font-black text-primary uppercase tracking-widest">Mobile Number</label>
                            <input type="tel" id="mobileInput" placeholder="9876543210" maxlength="10" 
                                value="@sessionMobile"
                                class="w-full bg-white border-2 border-slate-100 rounded-2xl px-6 py-5 text-xl font-bold tracking-[0.1em] focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all placeholder:text-slate-200" />
                            <div id="mobileLoader" class="absolute right-6 top-1/2 -translate-y-1/2 hidden">
                                <span class="material-symbols-outlined animate-spin text-primary">sync</span>
                            </div>
                        </div>

                        <button onclick="showSecondStep()" id="nextBtn" class="btn-primary w-full py-5 rounded-2xl text-white font-bold text-lg uppercase tracking-widest">
                            Continue
                        </button>
                    </div>

                    <div class="mt-12 text-center">
                        <a href="/CustomerDashboard/Login" class="text-slate-400 font-bold text-xs uppercase tracking-widest hover:text-primary transition-colors">
                            Customer Dashboard Login
                        </a>
                    </div>
                </div>

                <!-- Step 2: Details + Code -->
                <div id="step2" class="step-content absolute inset-0 opacity-0 pointer-events-none translate-x-20">
                    <div class="flex items-center gap-4 mb-10">
                        <button onclick="showFirstStep()" class="p-2 h-10 w-10 flex items-center justify-center rounded-xl bg-slate-100 text-slate-400 hover:bg-slate-200 hover:text-slate-600 transition-all">
                            <span class="material-symbols-outlined">arrow_back</span>
                        </button>
                        <div class="flex-1">
                             <span class="text-xs font-black text-primary uppercase tracking-[0.2em] block">Step 02</span>
                             <h1 class="text-2xl font-black text-slate-800">Finalize Reward</h1>
                        </div>
                    </div>

                    <form action="/Redeem/Submit" method="post" id="redeemForm" class="space-y-6">
                        <input type="hidden" name="mobileNumber" id="finalMobile" value="@sessionMobile" />
                        
                        <div class="grid grid-cols-1 gap-5">
                            <div class="relative">
                                <label class="absolute -top-2.5 left-4 bg-white px-1.5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Full Name</label>
                                <input type="text" name="userName" id="nameInput" required value="@sessionName"
                                    class="w-full border-2 border-slate-100 rounded-xl px-5 py-4 font-bold text-slate-700 focus:border-primary outline-none transition-all" />
                            </div>

                            <div class="grid grid-cols-2 gap-4">
                                <div class="relative">
                                    <label class="absolute -top-2.5 left-4 bg-white px-1.5 text-[10px] font-black text-slate-400 uppercase tracking-widest">City</label>
                                    <input type="text" name="city" id="cityInput" required value="@sessionCity"
                                        class="w-full border-2 border-slate-100 rounded-xl px-4 py-4 font-bold text-slate-700 focus:border-primary outline-none transition-all" />
                                </div>
                                <div class="relative">
                                    <label class="absolute -top-2.5 left-4 bg-white px-1.5 text-[10px] font-black text-slate-400 uppercase tracking-widest">District</label>
                                    <input type="text" name="district" id="districtInput" required value="@sessionDistrict"
                                        class="w-full border-2 border-slate-100 rounded-xl px-4 py-4 font-bold text-slate-700 focus:border-primary outline-none transition-all" />
                                </div>
                            </div>

                            <div class="relative">
                                <label class="absolute -top-2.5 left-4 bg-white px-1.5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Role/Category</label>
                                <select name="category" id="categoryInput" required 
                                    class="w-full border-2 border-slate-100 rounded-xl px-5 py-4 font-bold text-slate-700 focus:border-primary outline-none transition-all appearance-none bg-white">
                                    <option value="" disabled selected>Select Category</option>
                                    <option value="Contractor">Contractor</option>
                                    <option value="Builder">Builder</option>
                                    <option value="Supervisor">Supervisor</option>
                                    <option value="Painter">Painter</option>
                                    <option value="Dealer">Dealer</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>

                            <div class="relative mt-2">
                                <label class="absolute -top-3 left-4 bg-white px-2 text-[10px] font-black text-indigo-600 uppercase tracking-[0.2em]">Redeem Code</label>
                                <input type="text" name="code" id="codeInput" value="@ViewBag.Code" placeholder="Enter QR Code"
                                    class="w-full border-2 border-indigo-200 bg-indigo-50/30 rounded-2xl px-6 py-5 text-xl font-bold tracking-[0.1em] text-indigo-700 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all placeholder:text-indigo-300" />
                                <div id="codeStatus" class="mt-2 text-[11px] font-bold hidden flex items-center gap-1 ml-1"></div>
                                <p class="text-[10px] text-slate-400 font-bold mt-2 ml-1 italic">* Optional if just registering</p>
                            </div>

                            <button type="button" onclick="startScanner()" class="w-full py-4 border-2 border-dashed border-indigo-200 rounded-2xl flex items-center justify-center gap-3 text-indigo-600 font-bold hover:bg-indigo-50 transition-colors">
                                <span class="material-symbols-outlined">qr_code_scanner</span>
                                Scan QR Code
                            </button>
                        </div>

                        <button type="submit" id="submitBtn" class="btn-primary w-full py-5 rounded-2xl text-white font-bold text-lg uppercase tracking-widest mt-4">
                            Claim Reward 🎁
                        </button>
                    </form>
                </div>

                <!-- QR Scanner Modal -->
                <div id="qr-modal" class="fixed inset-0 z-[100] hidden flex flex-col items-center justify-center p-4 bg-slate-900/95 backdrop-blur-md">
                    <div class="w-full max-w-sm bg-white rounded-[2.5rem] overflow-hidden shadow-2xl relative">
                        <div class="p-6 border-b flex justify-between items-center bg-slate-50">
                            <h3 class="font-black text-slate-800 uppercase tracking-widest text-sm">Scan QR Code</h3>
                            <button type="button" onclick="stopScanner()" class="h-10 w-10 flex items-center justify-center rounded-xl bg-slate-100 text-slate-400 hover:bg-slate-200 hover:text-slate-600 transition-all">
                                <span class="material-symbols-outlined">close</span>
                            </button>
                        </div>
                        <div class="p-4">
                            <div id="reader" class="rounded-2xl overflow-hidden border-4 border-slate-100"></div>
                        </div>
                        <div class="p-6 text-center space-y-2">
                            <p class="text-sm text-slate-500 font-bold">Position QR code inside the frame</p>
                            <p class="text-[10px] text-slate-400 font-medium uppercase tracking-[0.2em]">Scanner will automatically detect</p>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Footer Info -->
        <p id="poweredBy" class="text-center text-[9px] font-bold text-slate-300 mt-20 uppercase tracking-[0.3em]">
            Developed by Informa Pavilion
        </p>
    </div>
</main>

<script>
    const steps = {
        insta: document.getElementById('instaStep'),
        step1: document.getElementById('step1'),
        step2: document.getElementById('step2')
    };

    function showFirstStep() {
        if(steps.insta) {
            steps.insta.classList.add('fade-out');
            steps.insta.classList.remove('fade-in');
        }
        steps.step1.classList.add('fade-in');
        steps.step1.classList.remove('opacity-0', 'pointer-events-none', 'translate-x-20');
        steps.step1.classList.remove('fade-out');
        
        steps.step2.classList.add('opacity-0', 'pointer-events-none', 'translate-x-20');
        steps.step2.classList.remove('fade-in');
    }

    function showSecondStep() {
        const mobile = document.getElementById('mobileInput').value;
        if(mobile.length < 10) {
            alert("Please enter a valid 10-digit mobile number.");
            return;
        }
        
        document.getElementById('finalMobile').value = mobile;
        
        steps.step1.classList.add('fade-out');
        steps.step1.classList.remove('fade-in');
        
        setTimeout(() => {
            steps.step2.classList.add('fade-in');
            steps.step2.classList.remove('opacity-0', 'pointer-events-none', 'translate-x-20');
            steps.step2.classList.remove('fade-out');
        }, 100);
    }

    // Auto-fetch on mobile input
    const mobileInput = document.getElementById('mobileInput');
    const loader = document.getElementById('mobileLoader');

    mobileInput?.addEventListener('input', function() {
        if(this.value.length === 10) {
            fetchCustomer(this.value);
        }
    });

    async function fetchCustomer(mobile) {
        loader.classList.remove('hidden');
        try {
            const resp = await fetch(`/Redeem/GetCustomer?mobileNumber=${mobile}`);
            if(resp.ok) {
                const data = await resp.json();
                document.getElementById('nameInput').value = data.name || '';
                document.getElementById('cityInput').value = data.city || '';
                document.getElementById('districtInput').value = data.district || '';
                document.getElementById('categoryInput').value = data.category || '';
            }
        } catch(e) {}
        loader.classList.add('hidden');
    }

    async function markFollowed() {
        try {
            await fetch('/Redeem/SetInstagramFollowed', { method: 'POST' });
        } catch(e) {}
        setTimeout(showFirstStep, 3000); // Give user time to see the IG page
    }

    document.getElementById('redeemForm')?.addEventListener('submit', function() {
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="material-symbols-outlined animate-spin mr-2">progress_activity</span> Processing...';
    });

    // QR Scanner Implementation
    let html5QrCode;

    async function startScanner() {
        document.getElementById('qr-modal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        
        html5QrCode = new Html5Qrcode("reader");
        const config = { 
            fps: 15, 
            qrbox: { width: 250, height: 250 },
            aspectRatio: 1.0
        };

        try {
            await html5QrCode.start(
                { facingMode: "environment" }, 
                config, 
                onScanSuccess
            );
        } catch (err) {
            console.error(err);
            alert("Camera access failed. Please ensure you have granted permission and are using HTTPS.");
            stopScanner();
        }
    }

    async function stopScanner() {
        document.body.style.overflow = '';
        if (html5QrCode && html5QrCode.isScanning) {
            try {
                await html5QrCode.stop();
                html5QrCode.clear();
            } catch(e) {}
        }
        document.getElementById('qr-modal').classList.add('hidden');
    }

    async function onScanSuccess(decodedText, decodedResult) {
        await stopScanner();
        
        // Extract code if it's a URL (e.g., https://.../?code=XYZ)
        let extractedCode = decodedText;
        if (decodedText.includes('?code=')) {
            try {
                const url = new URL(decodedText);
                extractedCode = url.searchParams.get('code') || decodedText.split('?code=')[1];
            } catch(e) {
                extractedCode = decodedText.split('?code=')[1];
            }
        }
        
        const codeInput = document.getElementById('codeInput');
        codeInput.value = extractedCode;
        
        // Haptic feedback if available
        if (window.navigator.vibrate) {
            window.navigator.vibrate(100);
        }

        await checkScannedCode(extractedCode);
    }

    async function checkScannedCode(code) {
        const statusEl = document.getElementById('codeStatus');
        statusEl.innerHTML = '<span class="material-symbols-outlined animate-spin text-[14px]">sync</span> Checking eligibility...';
        statusEl.classList.remove('hidden', 'text-green-600', 'text-red-600', 'text-blue-600');
        statusEl.classList.add('text-blue-600', 'flex');

        try {
            const resp = await fetch(`/Redeem/CheckCode?code=${encodeURIComponent(code)}`);
            if (resp.ok) {
                const data = await resp.json();
                if (data.success) {
                    statusEl.innerHTML = `<span class="material-symbols-outlined text-[14px]">check_circle</span> ${data.message}`;
                    statusEl.classList.replace('text-blue-600', 'text-green-600');
                } else {
                    statusEl.innerHTML = `<span class="material-symbols-outlined text-[14px]">error</span> ${data.message}`;
                    statusEl.classList.replace('text-blue-600', 'text-red-600');
                }
            } else {
                throw new Error("API Error");
            }
        } catch (e) {
            statusEl.innerHTML = '<span class="material-symbols-outlined text-[14px]">warning</span> Unable to verify code right now.';
            statusEl.classList.replace('text-blue-600', 'text-red-600');
        }
    }

    // Auto-check if code is manually entered or pre-filled
    const codeInput = document.getElementById('codeInput');
    codeInput?.addEventListener('blur', function() {
        if(this.value.trim().length > 0) {
            checkScannedCode(this.value.trim());
        }
    });

    // Handle initial state if pre-filled
    window.onload = () => {
        const urlParams = new URLSearchParams(window.location.search);
        const autoScan = urlParams.get('autoScan') === 'true';

        if(mobileInput && mobileInput.value.length === 10) {
            fetchCustomer(mobileInput.value);
            
            // If we have a mobile number in session, skip to step 2
            showSecondStep();
            
            if (autoScan) {
                setTimeout(startScanner, 500); // Small delay for smooth transition
            }
        }
        @if(ViewBag.Code != null && !string.IsNullOrEmpty(sessionMobile)) {
            <text>
            showSecondStep();
            checkScannedCode('@ViewBag.Code');
            </text>
        }
    };
</script>
