@model QRRewardPlatform.Models.WebsiteEnquiry
@{
    ViewData["Title"] = $"Enquiry #{Model.EnquiryId}";
}

<div class="mb-6 flex items-center gap-4">
    <a href="/EnquiryManagement" class="p-2 hover:bg-gray-100 rounded-lg transition text-gray-400">
        <i class="fas fa-arrow-left"></i>
    </a>
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Enquiry Details</h1>
        <p class="text-sm text-gray-500">View and manage enquiry from @Model.Name</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Info -->
    <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
                <h3 class="font-bold text-gray-900">Personal Information</h3>
                @if (Model.IsDuplicate)
                {
                    <span class="px-3 py-1 bg-red-100 text-red-700 text-xs font-bold rounded-full uppercase">Recent Duplicate</span>
                }
            </div>
            <div class="p-6 grid grid-cols-1 sm:grid-cols-2 gap-y-6 gap-x-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Full Name</label>
                    <p class="text-gray-900 font-medium">@Model.Name</p>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Mobile Number</label>
                    <p class="text-gray-900 font-medium">@Model.Mobile</p>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Email Address</label>
                    <p class="text-gray-900 font-medium">@Model.Email</p>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Role / Type</label>
                    <p class="text-gray-900 font-medium">@Model.RoleType</p>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">City</label>
                    <p class="text-gray-900 font-medium">@Model.City</p>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">State</label>
                    <p class="text-gray-900 font-medium">@Model.State</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 bg-indigo-50/50">
                <h3 class="font-bold text-indigo-900 flex items-center gap-2">
                    <i class="fas fa-box"></i> Product & Quantity
                </h3>
            </div>
            <div class="p-6 grid grid-cols-1 sm:grid-cols-2 gap-y-6 gap-x-4">
                <div class="sm:col-span-2 p-3 bg-gray-50 rounded-lg border border-gray-100">
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Product Name</label>
                    <p class="text-lg font-bold text-gray-900">@(Model.ProductName ?? Model.ProductInterested ?? "N/A")</p>
                    @if (!string.IsNullOrEmpty(Model.ProductSlug))
                    {
                        <p class="text-xs text-indigo-500 font-medium">Slug: @Model.ProductSlug</p>
                    }
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Quantity</label>
                    <p class="text-2xl font-black text-indigo-600">@Model.Quantity</p>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Source Page</label>
                    <p class="text-gray-900 font-medium truncate" title="@Model.Source">@Model.Source</p>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.CartJson))
        {
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 bg-emerald-50/50">
                    <h3 class="font-bold text-emerald-900 flex items-center gap-2">
                        <i class="fas fa-shopping-cart"></i> Cart Items
                    </h3>
                </div>
                <div class="p-6">
                    <div class="bg-gray-900 p-4 rounded-lg overflow-x-auto">
                        <pre class="text-emerald-400 text-xs">@Model.CartJson</pre>
                    </div>
                    <p class="mt-2 text-[10px] text-gray-400 italic font-medium uppercase tracking-tighter">Raw Cart Data (JSON Format)</p>
                </div>
            </div>
        }

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h3 class="font-bold text-gray-900">Enquiry Message</h3>
            </div>
            <div class="p-6">
                <div class="p-4 bg-gray-50 rounded-lg text-gray-700 whitespace-pre-wrap italic">"@Model.Message"</div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
                <h3 class="font-bold text-gray-900">Digital Context & Location</h3>
                @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                {
                    <a href="https://www.google.com/maps?q=@Model.Latitude,@Model.Longitude" target="_blank" class="px-3 py-1 bg-red-100 text-red-700 text-xs font-bold rounded-full hover:bg-red-200 transition">
                        <i class="fas fa-map-marker-alt mr-1"></i> VIEW MAP
                    </a>
                }
            </div>
            <div class="p-6 grid grid-cols-1 sm:grid-cols-2 gap-y-6 gap-x-4 text-sm">
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Created From</label>
                    <p class="text-gray-900 font-medium">@Model.CreatedFrom</p>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Geo Location</label>
                    <p class="text-gray-900 font-medium">
                        @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                        {
                            <span>@Model.Latitude.Value.ToString("F4"), @Model.Longitude.Value.ToString("F4")</span>
                        }
                        else
                        {
                            <span class="text-gray-400 italic">Not available</span>
                        }
                    </p>
                </div>
                <div class="sm:col-span-2">
                    <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Page URL</label>
                    <a href="@Model.PageUrl" target="_blank" class="text-indigo-600 hover:text-indigo-800 break-all font-medium">@Model.PageUrl</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar / Actions -->
    <div class="space-y-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h3 class="font-bold text-gray-900">Update Status</h3>
            </div>
            <form action="/EnquiryManagement/UpdateStatus" method="post" class="p-6 space-y-4">
                <input type="hidden" name="id" value="@Model.Id" />
                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Set Status</label>
                    <select name="status" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm">
                        <option value="New" selected="@(Model.Status == "New")">New</option>
                        <option value="Contacted" selected="@(Model.Status == "Contacted")">Contacted</option>
                        <option value="Follow Up" selected="@(Model.Status == "Follow Up")">Follow Up</option>
                        <option value="Qualified" selected="@(Model.Status == "Qualified")">Qualified</option>
                        <option value="Quotation Sent" selected="@(Model.Status == "Quotation Sent")">Quotation Sent</option>
                        <option value="Converted" selected="@(Model.Status == "Converted")">Converted</option>
                        <option value="Closed Lost" selected="@(Model.Status == "Closed Lost")">Closed Lost</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Add Remark</label>
                    <textarea name="remarks" rows="3" placeholder="Enter follow-up details..." class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none text-sm" required></textarea>
                </div>
                <button type="submit" class="w-full py-2 bg-indigo-600 text-white font-bold rounded-lg hover:bg-indigo-700 transition">
                    Update & Save
                </button>
            </form>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
                <h3 class="font-bold text-gray-900">History / Remarks</h3>
                <span class="text-xs text-gray-400 font-medium">Auto-saved</span>
            </div>
            <div class="p-6 max-h-96 overflow-y-auto">
                @if (string.IsNullOrEmpty(Model.Remarks))
                {
                    <p class="text-sm text-gray-400 italic text-center py-4">No remarks yet.</p>
                }
                else
                {
                    <div class="space-y-4">
                        @foreach (var remark in Model.Remarks.Split('\n', StringSplitOptions.RemoveEmptyEntries).Reverse())
                        {
                            <div class="p-3 bg-gray-50 rounded-lg border-l-4 border-indigo-400 shadow-sm">
                                <p class="text-sm text-gray-700 whitespace-pre-wrap">@remark</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
        
        <div class="bg-gray-100 p-4 rounded-xl">
            <div class="flex items-center gap-3 text-gray-500 text-xs font-semibold">
                <i class="far fa-clock"></i>
                <span>Enquiry received on @(DateTime.TryParse(Model.CreatedAt, out var dt) ? dt.ToString("dd MMM yyyy HH:mm") : Model.CreatedAt)</span>
            </div>
        </div>
    </div>
</div>
