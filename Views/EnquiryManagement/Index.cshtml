@model IEnumerable<QRRewardPlatform.Models.WebsiteEnquiry>
@{
    ViewData["Title"] = "Website Enquiries";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Website Enquiries</h1>
        <p class="text-sm text-gray-500">Manage and track enquiries received from the website</p>
    </div>
</div>

<!-- Analytics Cards -->
@{
    var stats = ViewBag.Analytics as QRRewardPlatform.Services.EnquiryAnalytics;
}
@if (stats != null)
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-6">
        <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100">
            <div class="text-xs font-semibold text-gray-400 uppercase mb-1">Total Enquiries</div>
            <div class="text-2xl font-bold text-gray-900">@stats.TotalEnquiries</div>
        </div>
        <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100">
            <div class="text-xs font-semibold text-gray-400 uppercase mb-1">Today's Enquiries</div>
            <div class="text-2xl font-bold text-blue-600">@stats.TodayEnquiries</div>
        </div>
        <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100">
            <div class="text-xs font-semibold text-gray-400 uppercase mb-1">Top Product</div>
            <div class="text-sm font-bold text-gray-900 truncate" title="@(stats.TopProducts.FirstOrDefault()?.ProductName)">
                @(stats.TopProducts.FirstOrDefault()?.ProductName ?? "N/A")
            </div>
        </div>
        <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100">
            <div class="text-xs font-semibold text-gray-400 uppercase mb-1">Enquiry Qty</div>
            <div class="text-2xl font-bold text-indigo-600">@stats.TotalQuantity</div>
        </div>
        <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100">
            <div class="text-xs font-semibold text-gray-400 uppercase mb-1">Product Leads</div>
            <div class="text-2xl font-bold text-emerald-600">@stats.ProductWiseSummary.Count</div>
        </div>
    </div>
}

<!-- Filters -->
<div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100 mb-6">
    <form method="get" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Status</label>
            <select name="status" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none">
                <option value="">All Statuses</option>
                <option value="New" selected="@(ViewBag.Status == "New")">New</option>
                <option value="Contacted" selected="@(ViewBag.Status == "Contacted")">Contacted</option>
                <option value="Follow Up" selected="@(ViewBag.Status == "Follow Up")">Follow Up</option>
                <option value="Qualified" selected="@(ViewBag.Status == "Qualified")">Qualified</option>
                <option value="Quotation Sent" selected="@(ViewBag.Status == "Quotation Sent")">Quotation Sent</option>
                <option value="Converted" selected="@(ViewBag.Status == "Converted")">Converted</option>
                <option value="Closed Lost" selected="@(ViewBag.Status == "Closed Lost")">Closed Lost</option>
            </select>
        </div>
        <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">City</label>
            <input type="text" name="city" value="@ViewBag.City" placeholder="Filter by City" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none" />
        </div>
        <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Product</label>
            <input type="text" name="product" value="@ViewBag.Product" placeholder="Filter by Product" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none" />
        </div>
        <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Source</label>
            <input type="text" name="source" value="@ViewBag.Source" placeholder="Filter by Source" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none" />
        </div>
        <div class="flex items-end gap-2">
            <button type="submit" class="flex-1 px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition text-sm font-medium">
                <i class="fas fa-filter mr-2"></i> Filter
            </button>
            <a href="/Enquiries" class="px-4 py-2 bg-gray-100 text-gray-600 rounded-lg hover:bg-gray-200 transition text-sm font-medium">
                Reset
            </a>
        </div>
    </form>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm text-gray-600">
            <thead class="bg-gray-50 text-gray-700">
                <tr>
                    <th class="px-6 py-4 font-semibold uppercase tracking-wider text-xs">ID</th>
                    <th class="px-6 py-4 font-semibold uppercase tracking-wider text-xs">Date</th>
                    <th class="px-6 py-4 font-semibold uppercase tracking-wider text-xs">Name</th>
                    <th class="px-6 py-4 font-semibold uppercase tracking-wider text-xs">Mobile</th>
                    <th class="px-6 py-4 font-semibold uppercase tracking-wider text-xs">City</th>
                    <th class="px-6 py-4 font-semibold uppercase tracking-wider text-xs">Product</th>
                    <th class="px-6 py-4 font-semibold uppercase tracking-wider text-xs">Qty</th>
                    <th class="px-6 py-4 font-semibold uppercase tracking-wider text-xs">Source</th>
                    <th class="px-6 py-4 font-semibold uppercase tracking-wider text-xs">Status</th>
                    <th class="px-6 py-4 text-right font-semibold uppercase tracking-wider text-xs">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 transition @(item.IsDuplicate ? "bg-red-50" : "")">
                        <td class="px-6 py-4 font-medium text-gray-900">
                            #@item.EnquiryId
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            @(DateTime.TryParse(item.CreatedAt, out var dt) ? dt.ToString("dd MMM yyyy") : item.CreatedAt)
                        </td>
                        <td class="px-6 py-4">
                            <div class="font-medium text-gray-900">@item.Name</div>
                            <div class="text-xs text-gray-500">@item.Email</div>
                        </td>
                        <td class="px-6 py-4">@item.Mobile</td>
                        <td class="px-6 py-4">@item.City</td>
                        <td class="px-6 py-4">@(item.ProductName ?? item.ProductInterested)</td>
                        <td class="px-6 py-4 font-bold text-indigo-600">@item.Quantity</td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                                @item.Source
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            @{
                                var statusClass = item.Status switch
                                {
                                    "New" => "bg-blue-100 text-blue-800",
                                    "Contacted" => "bg-yellow-100 text-yellow-800",
                                    "Follow Up" => "bg-orange-100 text-orange-800",
                                    "Qualified" => "bg-emerald-100 text-emerald-800",
                                    "Quotation Sent" => "bg-purple-100 text-purple-800",
                                    "Converted" => "bg-green-100 text-green-800",
                                    "Closed Lost" => "bg-red-100 text-red-800",
                                    _ => "bg-gray-100 text-gray-800"
                                };
                            }
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @statusClass">
                                @item.Status
                            </span>
                            @if (item.IsDuplicate)
                            {
                                <span class="ml-1 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800" title="Recent Duplicate">
                                    <i class="fas fa-copy mr-1"></i> Dup
                                </span>
                            }
                        </td>
                        <td class="px-6 py-4 text-right">
                            <a href="/EnquiryManagement/Details/@item.Id" class="text-indigo-600 hover:text-indigo-900 font-medium">
                                Details
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="px-6 py-8 text-center text-gray-500 italic">
                            No enquiries found matching the filters.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Product Wise Summary Report -->
@if (stats != null && stats.ProductWiseSummary.Any())
{
    <div class="mt-8 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50 flex justify-between items-center">
            <h3 class="font-bold text-gray-900 text-sm uppercase tracking-wider">Product-Wise Enquiry Summary</h3>
            <span class="text-xs text-gray-400">Total Products: @stats.ProductWiseSummary.Count</span>
        </div>
        <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var prod in stats.ProductWiseSummary.OrderByDescending(p => p.Count))
                {
                    <div class="p-4 rounded-lg bg-gray-50 border border-gray-200 hover:border-indigo-200 transition">
                        <div class="text-sm font-bold text-gray-800 truncate mb-2" title="@prod.ProductName">@prod.ProductName</div>
                        <div class="flex justify-between items-center text-xs text-gray-500">
                            <span>Enquiries: <span class="font-bold text-gray-900">@prod.Count</span></span>
                            <span>Total Qty: <span class="font-bold text-indigo-600">@prod.TotalQuantity</span></span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
