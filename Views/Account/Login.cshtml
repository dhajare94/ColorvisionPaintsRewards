@{
    Layout = "_RedeemLayout";
    ViewData["Title"] = "Admin Login";
}

<div class="min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <div class="flex justify-center mb-4">
                <img src="~/images/logo.png" alt="Colorvision Paints" class="h-20 object-contain mx-auto" />
            </div>
            <h1 class="text-2xl font-bold text-gray-900">Colorvision Paints</h1>
            <p class="text-gray-500 mt-1">Sign in to admin panel</p>
        </div>

        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
            @if (ViewBag.Error != null)
            {
                <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm flex items-center gap-2">
                    <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                </div>
            }

            <form method="post" action="/Account/Login" class="space-y-5">
                @if (ViewBag.ReturnUrl != null)
                {
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                }
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="fas fa-user text-gray-400"></i>
                        </div>
                        <input type="text" name="Username" value="@Model.Username" required autofocus
                               class="w-full pl-11 pr-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                               placeholder="Enter username" />
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="fas fa-lock text-gray-400"></i>
                        </div>
                        <input type="password" name="Password" required
                               class="w-full pl-11 pr-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                               placeholder="Enter password" />
                    </div>
                </div>
                <div class="flex items-center">
                    <input type="checkbox" name="RememberMe" value="true" id="rememberMe" class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
                    <label for="rememberMe" class="ml-2 text-sm text-gray-600">Remember me</label>
                </div>
                <button type="submit" class="w-full py-3 bg-indigo-600 text-white font-medium rounded-xl hover:bg-indigo-700 transition shadow-lg shadow-indigo-200">
                    Sign In
                </button>
            </form>
        </div>

        <p class="text-center text-xs text-gray-400 mt-6">Powered by Informa Pavilion Software Solutions Pvt Ltd</p>
    </div>
</div>
